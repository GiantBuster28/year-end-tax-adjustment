# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/tax_adjustment

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── JWT (backend) ─────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-secure-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── MinIO (object storage) ────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=tax-attachments

# ── BFF ───────────────────────────────────────────────────────────────────────
BFF_PORT=4000
API_URL=http://api:8000
# Must match SECRET_KEY above so the BFF can verify tokens issued by the backend
JWT_SECRET=change-this-to-a-secure-random-string-in-production

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:4000

# ── PostgreSQL (direct access) ────────────────────────────────────────────────
POSTGRES_DB=tax_adjustment
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
